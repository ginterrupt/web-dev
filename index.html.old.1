<script>
  function filterBy(type, btn) {
    // update buttons
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const cards = document.querySelectorAll('.session-card');
    const rows = document.querySelectorAll('.parallel-row');
    const days = document.querySelectorAll('.day-section');

    if (type === 'all') {
      cards.forEach(c => c.classList.remove('hidden'));
      rows.forEach(r => r.classList.remove('hidden'));
      days.forEach(d => d.classList.remove('hidden'));
      return;
    }

    cards.forEach(card => {
      let show = false;
      if (type === 'day1' || type === 'day2') show = card.dataset.day === type;
      else if (type === 'slides') show = card.querySelector('.slides-link') !== null;
      else if (type === 'EN') show = card.dataset.lang && card.dataset.lang.includes('EN');
      else if (type === 'RU') show = card.dataset.lang === 'RU';
      else show = card.dataset.location === type;
      card.classList.toggle('hidden', !show);
    });

    // hide rows where all cards hidden
    rows.forEach(row => {
      const visible = row.querySelectorAll('.session-card:not(.hidden)');
      row.classList.toggle('hidden', visible.length === 0);
    });

    // hide days where all rows hidden
    days.forEach(day => {
      const visible = day.querySelectorAll('.parallel-row:not(.hidden)');
      day.classList.toggle('hidden', visible.length === 0);
    });
  }
</script>

