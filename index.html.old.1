    <div class="legend-item"><div class="legend-dot" style="background:var(--lang-en)"></div> English</div>
    <div class="legend-item"><div class="legend-dot" style="background:var(--lang-ru)"></div> Russian</div>
    <div class="legend-item"><div class="legend-dot" style="background:var(--lang-ge)"></div> Georgian</div>
  </div>

  <!-- ===== DAY 1 ===== -->
  <div class="day-section" data-day="day1">
    <div class="day-header">
      <div class="day-num">02</div>
      <div class="day-info">
        <h2>Saturday, 2 May</h2>
        <p>Sessions 1 – 5</p>
      </div>
    </div>

    <!-- 10:10 -->
    <div class="parallel-row">
      <div class="slot-time">10:10<br>– 11:10</div>
      <div class="sessions-group">
        <div class="session-card" data-location="Room 5-2" data-lang="EN" data-day="day1" style="--i:1">
          <div class="card-top">
            <span class="session-label">Session 1</span>
            <div class="badge-row">
              <span class="badge badge-location-room">Room 5-2</span>
              <span class="badge badge-lang-en">EN</span>
            </div>
          </div>
          <div class="card-title">Linking MYP planning to TOK thinking</div>
          <div class="card-speakers">Vladimir Rybkin &amp; Elvina Nazifova</div>
          <div class="card-institution">International Talent Academy of Tashkent</div>
          <div class="card-footer">
            <a class="slides-link" href="#" target="_blank">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="2" width="14" height="11" rx="1"/><path d="M5 15h6M8 13v2"/></svg>
              Slides
            </a>
          </div>
        </div>
        <div class="session-card" data-location="Library" data-lang="EN" data-day="day1" style="--i:2">
          <div class="card-top">
            <span class="session-label">Session 2</span>
            <div class="badge-row">
              <span class="badge badge-location-lib">Library</span>
              <span class="badge badge-lang-en">EN</span>
            </div>
          </div>
