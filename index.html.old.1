              პრეზენტაცია
            </a>
          </div>
        </div>
        <div class="session-card" data-location="Room 5-2" data-lang="GE/EN" data-day="day1" style="--i:4">
          <div class="card-top">
            <span class="session-label">Session 2</span>
            <div class="badge-row">
              <span class="badge badge-location-room">Room 5-2</span>
              <span class="badge badge-lang-multi">GE / EN</span>
