<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Building B — Conference Schedule</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1410;
    --paper: #f5f0e8;
    --cream: #ede7d9;
    --warm: #c8b89a;
    --accent: #8b4513;
    --accent2: #2d5016;
    --gold: #b8860b;
    --rust: #a0522d;
    --muted: #7a6e62;
    --lib: #2d5016;
    --room: #5a2d82;
    --lang-en: #1a4a6b;
    --lang-ru: #6b1a1a;
    --lang-ge: #1a6b3a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
  }

  /* NOISE TEXTURE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='512' height='512' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* HEADER */
  header {
    background: var(--ink);
    color: var(--paper);
    padding: 60px 40px 48px;
    position: relative;
    overflow: hidden;
  }

  header::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0; right: 0;
    height: 24px;
    background: var(--paper);
    clip-path: polygon(0 100%, 100% 100%, 100% 0, 50% 60%, 0 0);
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--warm);
    font-weight: 500;
  }

  h1 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  h1 em {
    font-style: italic;
    color: var(--warm);
  }

  .header-meta {
    display: flex;
    gap: 32px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--warm);
  }

  .meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  /* FILTER BAR */
  .filter-bar {
    background: var(--cream);
    border-bottom: 1px solid var(--warm);
    padding: 16px 40px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .filter-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    margin-right: 4px;
  }

  .filter-btn {
    border: 1.5px solid var(--warm);
    background: transparent;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    color: var(--muted);
    transition: all 0.18s;
    font-weight: 500;
  }

  .filter-btn:hover { background: var(--warm); color: var(--ink); border-color: var(--warm); }
  .filter-btn.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

  /* MAIN CONTENT */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 40px 80px;
  }

  /* DAY SECTION */
  .day-section { margin-bottom: 64px; }

  .day-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--ink);
  }

  .day-num {
    font-family: 'DM Serif Display', serif;
    font-size: 64px;
    line-height: 1;
    color: var(--warm);
    opacity: 0.5;
  }

  .day-info h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.8rem;
    line-height: 1.1;
  }

  .day-info p {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* TIME SLOT */
  .time-slot {
    margin-bottom: 4px;
  }

  .time-slot.is-break {
    margin-bottom: 16px;
  }

  /* BREAK CARD */
  .break-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 12px 20px;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 6px,
      rgba(200,184,154,0.15) 6px,
      rgba(200,184,154,0.15) 12px
    );
    border: 1px dashed var(--warm);
    border-radius: 6px;
    opacity: 0.75;
    margin-bottom: 16px;
  }

  .break-time {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    min-width: 110px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

  .break-label {
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
  }

  /* PARALLEL ROW */
  .parallel-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 0 20px;
    margin-bottom: 16px;
    align-items: start;
  }

  .slot-time {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    padding-top: 18px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
    line-height: 1.3;
    text-align: right;
  }

  .sessions-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
  }

  /* SESSION CARD */
  .session-card {
    background: white;
    border: 1.5px solid var(--cream);
    border-radius: 10px;
    padding: 20px 22px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: default;
  }

  .session-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(26,20,16,0.1);
  }

  .session-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent);
  }

  .session-card[data-location="Library"]::before { background: var(--lib); }
  .session-card[data-location="Room 5-2"]::before { background: var(--room); }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
    gap: 8px;
  }

  .session-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--muted);
  }

  .badge-row {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .badge-location-lib {
    background: rgba(45,80,22,0.1);
    color: var(--lib);
    border: 1px solid rgba(45,80,22,0.2);
  }

  .badge-location-room {
    background: rgba(90,45,130,0.1);
    color: var(--room);
    border: 1px solid rgba(90,45,130,0.2);
  }

  .badge-lang-en { background: rgba(26,74,107,0.1); color: var(--lang-en); border: 1px solid rgba(26,74,107,0.2); }
  .badge-lang-ru { background: rgba(107,26,26,0.1); color: var(--lang-ru); border: 1px solid rgba(107,26,26,0.2); }
  .badge-lang-ge { background: rgba(26,107,58,0.1); color: var(--lang-ge); border: 1px solid rgba(26,107,58,0.2); }
  .badge-lang-multi { background: rgba(107,80,26,0.1); color: #6b501a; border: 1px solid rgba(107,80,26,0.2); }

  .card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--ink);
  }

  .card-speakers {
    font-size: 12.5px;
    color: var(--muted);
    font-weight: 500;
    margin-bottom: 4px;
  }

  .card-institution {
    font-size: 11.5px;
    color: var(--warm);
    font-style: italic;
    margin-bottom: 12px;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 8px;
  }

  .slides-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 5px 12px;
    border: 1.5px solid currentColor;
    border-radius: 100px;
    transition: all 0.18s;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .slides-link:hover {
    background: var(--accent);
    color: white;
  }

  .slides-link svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .no-slides {
    font-size: 11px;
    color: var(--warm);
    font-style: italic;
  }

  /* HIDDEN */
  .hidden { display: none !important; }

  /* LEGEND */
  .legend {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    padding: 16px 20px;
    background: var(--cream);
    border-radius: 8px;
    border: 1px solid var(--warm);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 700px) {
    header { padding: 40px 20px 36px; }
    main { padding: 32px 20px 60px; }
    .filter-bar { padding: 12px 20px; }
    .parallel-row { grid-template-columns: 90px 1fr; gap: 0 12px; }
    .slot-time { font-size: 11px; }
    .day-num { font-size: 44px; }
    .sessions-group { grid-template-columns: 1fr; }
  }

  /* ANIMATION */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .session-card {
    animation: fadeUp 0.4s ease both;
  }

  .day-section:nth-child(1) .session-card { animation-delay: calc(var(--i, 0) * 40ms); }
  .day-section:nth-child(2) .session-card { animation-delay: calc(var(--i, 0) * 40ms + 0.1s); }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <span class="eyebrow">IB Conference · Building B</span>
    <h1>Sessions &amp; <em>Presentations</em></h1>
    <div class="header-meta">
      <div class="meta-item"><span class="meta-dot"></span>2–3 May 2025</div>
      <div class="meta-item"><span class="meta-dot"></span>Library &amp; Room 5-2</div>
      <div class="meta-item"><span class="meta-dot"></span>International IB Schools</div>
    </div>
  </div>
</header>

<div class="filter-bar">
  <div class="filter-inner">
    <span class="filter-label">Filter:</span>
    <button class="filter-btn active" onclick="filterBy('all', this)">All</button>
    <button class="filter-btn" onclick="filterBy('day1', this)">Saturday 2 May</button>
    <button class="filter-btn" onclick="filterBy('day2', this)">Sunday 3 May</button>
    <button class="filter-btn" onclick="filterBy('Library', this)">Library</button>
    <button class="filter-btn" onclick="filterBy('Room 5-2', this)">Room 5-2</button>
    <button class="filter-btn" onclick="filterBy('EN', this)">🇬🇧 EN</button>
    <button class="filter-btn" onclick="filterBy('RU', this)">🇷🇺 RU</button>
    <button class="filter-btn" onclick="filterBy('slides', this)">With Slides</button>
  </div>
</div>

<main>

  <!-- LEGEND -->
  <div class="legend">
