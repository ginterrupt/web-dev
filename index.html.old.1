          </div>
        </div>
      </div>
    </div>

    <!-- 15:05 -->
    <div class="parallel-row">
      <div class="slot-time">15:05<br>– 16:05</div>
      <div class="sessions-group">
        <div class="session-card" data-location="Library" data-lang="RU" data-day="day1" style="--i:6">
