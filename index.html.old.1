              პრეზენტაცია
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- LUNCH -->
    <div class="break-card">
      <span class="break-time">13:05 – 14:05</span>
      <span class="break-label">☕ Lunch Break</span>
    </div>

    <!-- 12:00 -->
    <div class="parallel-row">
      <div class="slot-time">12:00<br>– 13:00</div>
      <div class="sessions-group">
        <div class="session-card" data-location="Library" data-lang="EN" data-day="day1" style="--i:3">
